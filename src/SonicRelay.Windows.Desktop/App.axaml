<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SonicRelay.Windows.Desktop.App"
             RequestedThemeVariant="Dark">
  <!-- Dark theme is the default shell variant (issue #32); a light theme is prepared
       via ThemeVariant resources but not required in this phase. -->

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://SonicRelay.Windows.Desktop/Styles/Tokens.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://SonicRelay.Windows.Desktop/Styles/Controls.axaml" />
  </Application.Styles>
</Application>
