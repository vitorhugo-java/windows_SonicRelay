<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SonicRelay.Windows.Desktop.ViewModels"
             x:Class="SonicRelay.Windows.Desktop.Controls.SidebarNavigation"
             x:DataType="vm:MainWindowViewModel">
  <Border Background="{DynamicResource Sonic.SidebarBackgroundBrush}"
          BorderBrush="{DynamicResource Sonic.CardBorderBrush}"
          BorderThickness="0,0,1,0">
    <DockPanel LastChildFill="True" Margin="16,20">
      <!-- Brand mark -->
      <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="12" Margin="4,0,0,28">
        <Border Width="38" Height="38"
                CornerRadius="{StaticResource Sonic.RadiusMd}"
                Background="{DynamicResource Sonic.AccentBlueBrush}">
          <TextBlock Text="VH" FontWeight="Bold" FontSize="{StaticResource Sonic.FontSizeTitle}"
                     Foreground="{DynamicResource Sonic.TextPrimaryBrush}"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <StackPanel Spacing="0" VerticalAlignment="Center">
          <TextBlock Text="SonicRelay" FontWeight="SemiBold" FontSize="{StaticResource Sonic.FontSizeTitle}"
                     Foreground="{DynamicResource Sonic.TextPrimaryBrush}" />
          <TextBlock Text="Publisher" Classes="metric-label" />
        </StackPanel>
      </StackPanel>

      <ListBox ItemsSource="{Binding Navigation}"
               SelectedIndex="0"
               Background="Transparent"
               BorderThickness="0"
               Padding="0">
        <ListBox.Styles>
          <Style Selector="ListBoxItem">
            <!-- The container's DataContext is a NavigationItem; a reflection binding avoids
                 resolving against the control's compiled x:DataType (MainWindowViewModel). -->
            <Setter Property="IsEnabled" Value="{ReflectionBinding IsEnabled}" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="CornerRadius" Value="{StaticResource Sonic.RadiusMd}" />
            <Setter Property="Foreground" Value="{DynamicResource Sonic.TextSecondaryBrush}" />
          </Style>
          <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Sonic.CardBackgroundElevatedBrush}" />
          </Style>
          <Style Selector="ListBoxItem:selected">
            <Setter Property="Foreground" Value="{DynamicResource Sonic.AccentTealBrush}" />
          </Style>
          <Style Selector="ListBoxItem:disabled">
            <Setter Property="Opacity" Value="0.45" />
          </Style>
        </ListBox.Styles>
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="vm:NavigationItem">
            <StackPanel Orientation="Horizontal" Spacing="12">
              <TextBlock Text="{Binding Glyph}" FontSize="16" Width="20"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
              <TextBlock Text="{Binding Label}" FontSize="{StaticResource Sonic.FontSizeBody}"
                         VerticalAlignment="Center" />
            </StackPanel>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </DockPanel>
  </Border>
</UserControl>
