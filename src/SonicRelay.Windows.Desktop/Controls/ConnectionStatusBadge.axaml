<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:SonicRelay.Windows.Desktop.Converters"
             x:Class="SonicRelay.Windows.Desktop.Controls.ConnectionStatusBadge"
             x:Name="Root"
             HorizontalAlignment="Left">
  <Border BorderThickness="1"
          CornerRadius="{StaticResource Sonic.RadiusSm}"
          Padding="10,4"
          Background="{Binding Badge, ElementName=Root, Converter={x:Static conv:DashboardBadgeToBrushConverter.Instance}, ConverterParameter=Background}"
          BorderBrush="{Binding Badge, ElementName=Root, Converter={x:Static conv:DashboardBadgeToBrushConverter.Instance}, ConverterParameter=Border}">
    <TextBlock Text="{Binding Text, ElementName=Root}"
               FontSize="{StaticResource Sonic.FontSizeLabel}"
               FontWeight="SemiBold"
               Foreground="{Binding Badge, ElementName=Root, Converter={x:Static conv:DashboardBadgeToBrushConverter.Instance}, ConverterParameter=Foreground}" />
  </Border>
</UserControl>
