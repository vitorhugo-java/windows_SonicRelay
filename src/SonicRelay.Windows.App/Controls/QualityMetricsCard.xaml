<UserControl
    x:Class="SonicRelay.Windows.App.Controls.QualityMetricsCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SonicRelay.Windows.App.Controls">
  <Border Style="{StaticResource Sonic.CardStyle}">
    <StackPanel Spacing="14">
      <TextBlock Style="{StaticResource Sonic.CardTitleStyle}" Text="Quality" />
      <controls:MetricCardControl x:Name="LatencyMetric" Label="Latency / RTT" HorizontalAlignment="Stretch" />
      <controls:MetricCardControl x:Name="JitterMetric" Label="Jitter" HorizontalAlignment="Stretch" />
      <controls:MetricCardControl x:Name="PacketLossMetric" Label="Packet loss" HorizontalAlignment="Stretch" />
      <controls:MetricCardControl x:Name="BitrateMetric" Label="Bitrate" HorizontalAlignment="Stretch" />
    </StackPanel>
  </Border>
</UserControl>
