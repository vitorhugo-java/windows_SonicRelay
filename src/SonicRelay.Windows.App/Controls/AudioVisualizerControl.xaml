<UserControl
    x:Class="SonicRelay.Windows.App.Controls.AudioVisualizerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Height="120" CornerRadius="12" Padding="12,10"
          Background="{StaticResource Sonic.CardBackgroundElevatedBrush}"
          BorderBrush="{StaticResource Sonic.CardBorderBrush}" BorderThickness="1">
    <StackPanel x:Name="BarsPanel" Orientation="Horizontal" Spacing="3"
                HorizontalAlignment="Center" VerticalAlignment="Bottom" />
  </Border>
</UserControl>
