<UserControl
    x:Class="SonicRelay.Windows.App.Controls.ConnectionStatusCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SonicRelay.Windows.App.Controls">
  <Border Style="{StaticResource Sonic.CardStyle}">
    <StackPanel Spacing="14">
      <TextBlock Style="{StaticResource Sonic.CardTitleStyle}" Text="Connection" />

      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Style="{StaticResource Sonic.MetricLabelStyle}" Text="Session" VerticalAlignment="Center" />
        <controls:StatusBadgeControl x:Name="SessionBadge" Grid.Column="1" />
      </Grid>
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Style="{StaticResource Sonic.MetricLabelStyle}" Text="Signaling" VerticalAlignment="Center" />
        <controls:StatusBadgeControl x:Name="SignalingBadge" Grid.Column="1" />
      </Grid>
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Style="{StaticResource Sonic.MetricLabelStyle}" Text="WebRTC / ICE" VerticalAlignment="Center" />
        <controls:StatusBadgeControl x:Name="WebRtcBadge" Grid.Column="1" />
      </Grid>

      <Border Height="1" Background="{StaticResource Sonic.DividerBrush}" Margin="0,2" />

      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Style="{StaticResource Sonic.MetricLabelStyle}" Text="Mode" VerticalAlignment="Center" />
        <TextBlock x:Name="ModeText" Grid.Column="1" Foreground="{StaticResource Sonic.TextPrimaryBrush}"
                   FontSize="14" FontWeight="SemiBold" Text="—" />
      </Grid>
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Style="{StaticResource Sonic.MetricLabelStyle}" Text="Session code" VerticalAlignment="Center" />
        <TextBlock x:Name="CodeText" Grid.Column="1" Foreground="{StaticResource Sonic.AccentTealBrush}"
                   FontSize="16" FontWeight="Bold" Text="—" />
      </Grid>
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Style="{StaticResource Sonic.MetricLabelStyle}" Text="Viewers" VerticalAlignment="Center" />
        <TextBlock x:Name="ViewerText" Grid.Column="1" Foreground="{StaticResource Sonic.TextPrimaryBrush}"
                   FontSize="14" FontWeight="SemiBold" Text="0" />
      </Grid>
    </StackPanel>
  </Border>
</UserControl>
