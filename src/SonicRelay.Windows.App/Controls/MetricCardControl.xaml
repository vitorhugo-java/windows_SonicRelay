<UserControl
    x:Class="SonicRelay.Windows.App.Controls.MetricCardControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Background="{StaticResource Sonic.CardBackgroundElevatedBrush}"
          BorderBrush="{StaticResource Sonic.CardBorderBrush}" BorderThickness="1"
          CornerRadius="12" Padding="16,12" MinWidth="120">
    <StackPanel Spacing="4">
      <TextBlock x:Name="LabelText" Style="{StaticResource Sonic.MetricLabelStyle}" Text="Label" />
      <TextBlock x:Name="ValueText" Style="{StaticResource Sonic.MetricValueStyle}" Text="—" />
    </StackPanel>
  </Border>
</UserControl>
