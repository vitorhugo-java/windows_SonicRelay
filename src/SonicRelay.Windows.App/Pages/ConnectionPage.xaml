<Page x:Class="SonicRelay.Windows.App.Pages.ConnectionPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer><StackPanel Padding="24" Spacing="12" MaxWidth="640" HorizontalAlignment="Left">
    <TextBlock FontSize="{StaticResource TitleFontSize}" FontWeight="SemiBold" Text="Connection"/>

    <!-- Sign-in form: shown only while signed out. -->
    <StackPanel x:Name="SignInPanel" Spacing="12">
      <TextBlock Text="Configure the backend and sign in to prepare this Windows publisher." TextWrapping="Wrap"/>
      <TextBox x:Name="BackendUrlBox" Header="Backend URL" Text="https://sonicrelay-api.hugodotnet.dev" PlaceholderText="https://relay.example.com/"/>
      <TextBox x:Name="EmailBox" Header="Email" InputScope="EmailSmtpAddress"/>
      <PasswordBox x:Name="PasswordBox" Header="Password"/>
      <StackPanel Orientation="Horizontal" Spacing="12">
        <Button x:Name="LoginButton" Content="Sign in and prepare device" Click="Login_Click" Style="{StaticResource AccentButtonStyle}"/>
        <Button x:Name="CreateAccountButton" Content="Create account" Click="CreateAccount_Click"/>
      </StackPanel>
    </StackPanel>

    <!-- Account summary: shown only while signed in. Just the email and a log-out action. -->
    <StackPanel x:Name="AccountPanel" Spacing="12" Visibility="Collapsed">
      <TextBlock Text="Signed in as" Opacity="0.7"/>
      <TextBlock x:Name="AccountEmailText" FontSize="{StaticResource TitleFontSize}" FontWeight="SemiBold"/>
      <Button x:Name="LogoutButton" Content="Log out" Click="Logout_Click"/>
    </StackPanel>

    <ProgressRing x:Name="BusyRing" Width="24" Height="24" IsActive="False" HorizontalAlignment="Left"/>
    <InfoBar x:Name="ErrorBar" Severity="Error" IsOpen="False" IsClosable="False"/>
  </StackPanel></ScrollViewer>
</Page>
