<Page
    x:Class="SonicRelay.Windows.App.Pages.PublisherDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SonicRelay.Windows.App.Controls">
  <ScrollViewer>
    <StackPanel Padding="24" Spacing="16" MaxWidth="920" HorizontalAlignment="Stretch">
      <VisualStateManager.VisualStateGroups>
        <VisualStateGroup>
          <VisualState x:Name="Wide">
            <VisualState.StateTriggers>
              <AdaptiveTrigger MinWindowWidth="720" />
            </VisualState.StateTriggers>
          </VisualState>
          <VisualState x:Name="Narrow">
            <VisualState.StateTriggers>
              <AdaptiveTrigger MinWindowWidth="0" />
            </VisualState.StateTriggers>
            <VisualState.Setters>
              <Setter Target="SecondColumn.Width" Value="0" />
              <Setter Target="QualityCard.(Grid.Column)" Value="0" />
              <Setter Target="QualityCard.(Grid.Row)" Value="1" />
            </VisualState.Setters>
          </VisualState>
        </VisualStateGroup>
      </VisualStateManager.VisualStateGroups>

      <StackPanel Orientation="Horizontal" Spacing="12">
        <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource Sonic.TextPrimaryBrush}" Text="Publisher" />
        <controls:StatusBadgeControl x:Name="HeadlineBadge" VerticalAlignment="Center" />
      </StackPanel>

      <Border Style="{StaticResource Sonic.CardStyle}">
        <StackPanel Spacing="12">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Style="{StaticResource Sonic.CardTitleStyle}" Text="Audio monitor" />
            <TextBlock x:Name="LevelText" Grid.Column="1" Foreground="{StaticResource Sonic.TextMutedBrush}"
                       FontSize="13" VerticalAlignment="Center" Text="—" />
          </Grid>
          <controls:AudioVisualizerControl x:Name="Visualizer" />
        </StackPanel>
      </Border>

      <Grid ColumnSpacing="16" RowSpacing="16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition x:Name="SecondColumn" Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <controls:ConnectionStatusCard x:Name="ConnectionCard" Grid.Row="0" Grid.Column="0" />
        <controls:QualityMetricsCard x:Name="QualityCard" Grid.Row="0" Grid.Column="1" />
      </Grid>
    </StackPanel>
  </ScrollViewer>
</Page>
